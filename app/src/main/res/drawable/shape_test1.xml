<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 指定了形状内部的填充颜色 -->
    <solid android:color="#ff66aa" />
    <!-- 指定了形状轮廓的粗细与颜色 -->
    <stroke
        android:width="1dp"
        android:color="#aaaaaa" />

    <corners
        android:radius="20dp" />
    <padding
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp"/>

    <stroke
        android:width="2dp"
        android:color="#FF0000"
        android:dashWidth="5dp"
        android:dashGap="0dp"/>

    <gradient
        android:startColor="@color/black"
        android:endColor="@color/white"
        android:angle="0"
        android:gradientRadius="150dp"
        android:centerX="50%"
        android:centerY="50%"/>


</shape>