<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/button_okhttp_get"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="okhttp请求"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_clear"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="清空"
        app:layout_constraintStart_toEndOf="@id/button_okhttp_get"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_file_upload"
        android:layout_width="120dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="okhttp文件上传"
        android:textSize="8sp"
        app:layout_constraintStart_toEndOf="@id/button_clear"
        app:layout_constraintTop_toTopOf="parent" />
    <Button
        android:id="@+id/button_send_order_broadcast"
        android:layout_width="120dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="发送接收有序广播"
        android:textSize="8sp"
        app:layout_constraintStart_toEndOf="@id/button_clear"
        app:layout_constraintTop_toBottomOf="@id/button_file_upload" />
    <Button
        android:id="@+id/button_send_static_broadcast"
        android:layout_width="110dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="发送静态广播"
        android:textSize="8sp"
        app:layout_constraintStart_toStartOf="@id/button_clear"
        app:layout_constraintTop_toBottomOf="@id/button_clear" />

    <Button
        android:id="@+id/button_change_activity"
        android:layout_width="100dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="跳转activity"
        android:textSize="8sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_okhttp_get" />



    <Button
        android:id="@+id/button_test_activity"
        android:layout_width="100dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="test activity"
        android:textSize="8sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/text_receive_okhttp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_change_activity" />
    <TextView
        android:id="@+id/text_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_receive_okhttp" />

</androidx.constraintlayout.widget.ConstraintLayout>