<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/button_sharedpreference"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="存储"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_four_zujian"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="四大组件"
        app:layout_constraintStart_toEndOf="@id/button_sharedpreference"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_seng_broadcast"
        android:layout_width="120dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="发送接收标准广播"
        android:textSize="8sp"
        app:layout_constraintStart_toEndOf="@id/button_four_zujian"
        app:layout_constraintTop_toTopOf="parent" />
    <Button
        android:id="@+id/button_send_order_broadcast"
        android:layout_width="120dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="发送接收有序广播"
        android:textSize="8sp"
        app:layout_constraintStart_toEndOf="@id/button_four_zujian"
        app:layout_constraintTop_toBottomOf="@id/button_seng_broadcast" />
    <Button
        android:id="@+id/button_send_static_broadcast"
        android:layout_width="110dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="发送静态广播"
        android:textSize="8sp"
        app:layout_constraintStart_toStartOf="@id/button_four_zujian"
        app:layout_constraintTop_toBottomOf="@id/button_four_zujian" />

    <Button
        android:id="@+id/button_change_activity"
        android:layout_width="100dp"
        android:maxLines="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="跳转activity"
        android:textSize="8sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_sharedpreference" />






    <!-- Fragment 显示容器 -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/aharedpreference_fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fourzujian_fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />


</androidx.constraintlayout.widget.ConstraintLayout>